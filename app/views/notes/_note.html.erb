<div id="<%= dom_id(note) %>" class="border p-4 rounded bg-white shadow">
  <h2 class="text-lg font-bold"><%= note.title %></h2>
  <p class="mb-2"><%= note.content %></p>
  <div class="flex space-x-2">
    <%= link_to "Edit", edit_note_path(note), class: "text-blue-500" %>
    <%= link_to "Delete", note, method: :delete, data: { confirm: "Are you sure!" }, class: "text-red-500" %>
    <button></button>
  </div>
</div>